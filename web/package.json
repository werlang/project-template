{
  "name": "template-web",
  "version": "1.0.0",
  "description": "Generic Express and Webpack web service template",
  "type": "module",
  "scripts": {
    "production": "node app.js",
    "development": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --inspect=0.0.0.0 --watch app.js",
    "dev:client": "webpack serve",
    "build": "NODE_ENV=production webpack",
    "test": "playwright test"
  },
  "author": "Template Maintainers",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.6",
    "css-loader": "^7.1.1",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "express": "^4.19.2",
    "mini-css-extract-plugin": "^2.9.0",
    "mustache": "^4.2.0",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "webpack-dev-server": "^5.2.5"
  }
}
